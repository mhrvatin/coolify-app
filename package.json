{
	"name": "@mhrvatin/coolify-app",
	"version": "0.1.0",
	"description": "Shared Pulumi builder for deploying an app to Coolify (infra-hetzner), with optional shared-Postgres wiring.",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"prepare": "tsc -p tsconfig.build.json",
		"postinstall": "lefthook install || true",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"peerDependencies": {
		"@pulumi/command": "1.2.1",
		"@pulumi/pulumi": "3.250.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@pulumi/command": "1.2.1",
		"@pulumi/pulumi": "3.250.0",
		"@types/bun": "1.3.14",
		"lefthook": "2.1.9",
		"typescript": "5.9.3"
	}
}
